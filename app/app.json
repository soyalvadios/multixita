{
  "expo": {
    "name": "MultiXita",
    "slug": "acceso-umb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2E7D32"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "mx.umb.multixita"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "mx.umb.multixita"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "MultiXita necesita acceso a la cámara para fotografía de registro y credencial."
        }
      ],
      "expo-secure-store"
    ]
  }
}
